# Copy to .env and fill in. Any value here can also be passed on the CLI;
# CLI flags override .env values.
#
# Defaults below target a local vLLM OpenAI-compatible server:
#   vllm serve meta-llama/Llama-3.1-8B-Instruct --port 8000
# vLLM ignores the API key unless started with --api-key, so any string works.
#
# For chat-only endpoints (e.g. hosted gateways) use /v1/chat/completions;
# MODE=auto detects this from the URL, or set MODE=chat / MODE=completions explicitly.

# Required
ENDPOINT=http://localhost:8000/v1/completions
API_KEY=EMPTY
MODEL=meta-llama/Llama-3.1-8B-Instruct

# Optional
MODE=auto

# --- Prompt source ---
# Leave PROMPT unset to draw a random question from src/benchmark/questions.json per request.
# PROMPT=Explain the theory of relativity in simple terms.
# QUESTIONS_FILE=src/benchmark/questions.json   # custom JSON array; empty string disables
# SEED=-1                                       # -1 = nondeterministic; >=0 reproducible
# PROMPT_TOKENS=0                               # >0 → pad/truncate every prompt to N tokens

# --- Workload shape ---
MAX_TOKENS=128
CONCURRENT=1
TRIALS=5
WARMUP=1

# --- Open-loop QPS mode (closed-loop when QPS=0) ---
# QPS=0
# DURATION=0
# MAX_CONCURRENCY=0   # 0 = auto: max(32, ceil(qps*2)), capped at 256

# --- Sampling ---
# Greedy decoding (TEMPERATURE=0) gives identical output per prompt.
# IGNORE_EOS=true pins every request to exactly MAX_TOKENS so tokens/s isn't
# noisy from early-EOS variance. Disable both for OpenAI/strict gateways that
# reject unknown fields.
TEMPERATURE=0.0
TOP_P=1.0
IGNORE_EOS=true
TIMEOUT=120

# --- Streaming, tokenizer, logs ---
# STREAM=false                       # true → SSE with TTFT capture
# TOKENIZER=auto                     # auto | chars4 | tiktoken:<encoding>
# OUTPUT=runs.jsonl                  # .jsonl or .csv; warmup excluded
